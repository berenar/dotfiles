{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "env": {
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "sonnet",
  "deniedMcpServers": [
    {
      "serverName": "claude.ai Gmail"
    },
    {
      "serverName": "claude.ai Figma"
    },
    {
      "serverName": "claude.ai Amplitude"
    },
    {
      "serverName": "claude.ai Context7"
    },
    {
      "serverName": "plugin:celebrate-agentic-tools:context7"
    }
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/open-markdown-preview.sh",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/reset-tmux-window.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/set-claude-running.sh off",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/set-claude-running.sh on",
            "async": true
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/rename-tmux-window.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/set-claude-running.sh off",
            "async": true
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/flag-tmux-window.sh",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/play-sound-if-unfocused.sh /System/Library/Sounds/Funk.aiff"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/set-claude-running.sh off",
            "async": true
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/flag-tmux-window.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "celebrate-agentic-tools@celebrate-engineering": true,
    "security-guidance@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "celebrate-engineering": {
      "source": {
        "source": "github",
        "repo": "kartenmacherei/agent-builder-v2"
      }
    }
  },
  "outputStyle": "default",
  "spinnerTipsEnabled": true,
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "verbose": true,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
