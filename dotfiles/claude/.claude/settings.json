{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "sonnet",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/reset-tmux-window.sh",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/rename-tmux-window.sh",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/play-sound-if-unfocused.sh /System/Library/Sounds/Funk.aiff"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/play-sound-if-unfocused.sh /System/Library/Sounds/Blow.aiff"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "celebrate-agentic-tools@celebrate-engineering": true
  },
  "extraKnownMarketplaces": {
    "celebrate-engineering": {
      "source": {
        "source": "github",
        "repo": "kartenmacherei/agent-builder-v2"
      }
    }
  },
  "outputStyle": "default",
  "spinnerTipsEnabled": true,
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "autoMemoryEnabled": true,
  "verbose": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
