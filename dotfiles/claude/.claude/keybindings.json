{
  "$schema": "https://www.schemastore.org/claude-code-keybindings.json",
  "$docs": "https://code.claude.com/docs/en/keybindings",
  "bindings": [
    {
      "context": "Chat",
      "bindings": {
        "shift+tab": null,
        "tab": "chat:cycleMode",
        "meta+t": null,
        "ctrl+t": "chat:thinkingToggle",
        "ctrl+f": "chat:modelPicker"
      }
    },
    {
      "context": "Confirmation",
      "bindings": {
        "shift+tab": null,
        "tab": "confirm:cycleMode"
      }
    }
  ]
}
