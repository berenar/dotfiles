{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "autoupdate": true,
  "username": "Bernat",
  "instructions": [
    // these are relative to where opencode is run from, therefore the global ones need full paths
    "/Users/berenar/dotfiles/dotfiles/opencode/.config/opencode/instructions/responding.md",
    "/Users/berenar/dotfiles/dotfiles/opencode/.config/opencode/instructions/plan-mode.md",
    "/Users/berenar/dotfiles/dotfiles/opencode/.config/opencode/instructions/build-mode.md",
    "/Users/berenar/dotfiles/dotfiles/opencode/.config/opencode/instructions/coding-preferences.md",
    "/Users/berenar/dotfiles/dotfiles/opencode/.config/opencode/instructions/testing.md",
    "/Users/berenar/dotfiles/dotfiles/opencode/.config/opencode/instructions/git-commit-workflow.md",
    "/Users/berenar/dotfiles/dotfiles/opencode/.config/opencode/instructions/identity.md",
    "/Users/berenar/dotfiles/dotfiles/opencode/.config/opencode/instructions/external-links.md",
    "/Users/berenar/dotfiles/dotfiles/opencode/.config/opencode/instructions/tooling-preferences.md",
    "CLAUDE.md",
    ".cursor/rules/*.md",
    "GEMINI.md",
    "WINDSURF.md",
  ],
  "plugin": ["cc-safety-net"],
  "permission": {
    "bash": {
      "make *": "allow",
      "echo *": "allow",
      "grep *": "allow",
      "cat *": "allow",
    },
  },
  "default_agent": "plan",
  "agent": {
    "plan": { "color": "#39C5CF" },
    "build": { "color": "#A855F7" },
  },
  "mcp": {
    // Quite useful
    "linear": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.linear.app/mcp"],
    },
    "sentry": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
    },
    "figma": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
    },
    "chrome-devtools": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
    },
    // Barely useful
    "github": {
      "enabled": false, // using gh cli instead
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}",
      },
    },
    "playwright": {
      "enabled": false, // using chrome-devtools-mcp instead
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
    },
    "notion": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
    },
    "mcp-mermaid": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-y", "mcp-mermaid"],
    },
  },
}
