#!/usr/bin/env bash

active_window_index() {
  tmux list-windows -t "$1" -F '#{window_active}' 2>/dev/null | awk '$1==1{print NR-1; exit}'
}

if [[ $1 == --nav ]]; then
  direction=$2
  session=$3
  windows=($(tmux list-windows -t "$session" -F '#{window_id}' 2>/dev/null))
  n=${#windows[@]}
  [[ $n -eq 0 ]] && exit 0
  idx=$(active_window_index "$session")
  if [[ $direction == prev ]]; then
    idx=$(( (idx - 1 + n) % n ))
  else
    idx=$(( (idx + 1) % n ))
  fi
  tmux select-window -t "${windows[idx]}"
  exit 0
fi

if [[ $1 == --preview ]]; then
  session=$2
  windows=($(tmux list-windows -t "$session" -F '#{window_id}' 2>/dev/null))
  n=${#windows[@]}
  [[ $n -eq 0 ]] && exit 0
  idx=$(active_window_index "$session")
  target=${windows[idx]}
  label=$(tmux display-message -p -t "$target" '#{window_index}:#{window_name}' 2>/dev/null)
  printf '\e[38;2;120;150;200m◀ %d/%d  %s  ▶\e[0m\n' "$((idx + 1))" "$n" "$label"
  tmux capture-pane -ep -t "$target" 2>/dev/null |
    awk 'NF {last=NR} {lines[NR]=$0} END {for (i = 1; i <= last; i++) print lines[i]}' |
    tail -n "$((FZF_PREVIEW_LINES - 1))"
  exit 0
fi

if [[ $1 == --list ]]; then
  reset=$'\e[0m'
  alert=$'\e[38;2;215;135;135m'

  # Amber "claude is thinking" colour, breathing on a 2s cosine cycle. Derived
  # from wall-clock time so it stays smooth across fzf's periodic reloads
  # without keeping any state between calls.
  pulse=$(awk -v t="$(date +%s.%N)" 'BEGIN {
    f = (1 - cos(3.141592653589793 * t)) / 2
    printf "%d;%d;%d", 120 + f * 110 + 0.5, 96 + f * 84 + 0.5, 46 + f * 34 + 0.5
  }')
  busy=$'\e[38;2;'"$pulse"'m'

  running_ids=" $(tmux list-windows -a -f '#{==:#{@claude_running},1}' -F '#{session_id}' 2>/dev/null | sort -u | tr '\n' ' ')"

  tmux list-sessions -F $'#{session_last_attached}\t#{session_id}\t#{session_name}\t#{?session_alerts,1,0}' |
    sort -rn |
    while IFS=$'\t' read -r _ id name alerts; do
      color=""
      [[ $running_ids == *" $id "* ]] && color=$busy
      [[ $alerts == 1 ]] && color=$alert
      if [[ -n $color ]]; then
        printf '%s %s%s ✻%s\n' "$id" "$color" "$name" "$reset"
      else
        printf '%s %s\n' "$id" "$name"
      fi
    done
  exit 0
fi

window=$(tmux display-message -p '#{window_id}')
tmux set -w -t "$window" window-style 'fg=#4d5660,bg=#10141a'
trap 'tmux set -w -t "$window" -u window-style' EXIT

selected=$(
  "$0" --list |
    fzf --reverse \
      --ansi \
      --with-nth 2.. \
      --preview "$0 --preview {1}" \
      --preview-window 'right:65%' \
      --bind "every(0.1):reload-sync($0 --list)" \
      --bind 'every(0.5):refresh-preview' \
      --bind "left:execute-silent($0 --nav prev {1})+refresh-preview" \
      --bind "right:execute-silent($0 --nav next {1})+refresh-preview"
)

[[ -z $selected ]] && exit 0

tmux switch-client -t "${selected%% *}"
